{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2022", "DOM"],
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "fixtures": ["web/fixtures.ts"]
    }
  },
  "include": ["web/**/*.ts", "tests/**/*.ts", "playwright.config.ts"]
}
